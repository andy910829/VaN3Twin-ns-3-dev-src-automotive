<?xml version="1.0" encoding="UTF-8"?>
<routes>

    <!-- ========================================== -->
    <!-- 1. 路徑定義                                -->
    <!-- ========================================== -->
    <route id="r_main" edges="E0 E5"/>

    <!-- ========================================== -->
    <!-- 2. 車輛類型定義                              -->
    <!--    - Car1: 緊急車輛 (EV)，極慢速移動路障         -->
    <!--    - Car2: 攻擊者，用於執行物理寄生與訊號干擾     -->
    <!--    - Car3/4/5: 受害車輛，高速行駛以產生強迫近效應 -->
    <!-- ========================================== -->
    <vType id="Car1" accel="5.0" decel="7.5" emergencyDecel="10" minGap="1.0" maxSpeed="10.0" laneChangeModel="LC2013" lcStrategic="-1" lcCooperative="-1" lcSpeedGain="0" lcKeepRight="0" />
    <vType id="Car2" accel="4.0" decel="7.5" emergencyDecel="10" minGap="1.0" maxSpeed="20.0" laneChangeModel="LC2013" lcStrategic="-1" lcCooperative="-1" lcSpeedGain="0" lcKeepRight="0"/>
    <vType id="Car3" accel="3.0" decel="7.5" emergencyDecel="10" minGap="1.0" maxSpeed="30.0" laneChangeModel="LC2013" lcStrategic="-1" lcCooperative="-1" lcSpeedGain="0" lcKeepRight="0"/>
    <vType id="Car4" accel="4.0" decel="7.5" emergencyDecel="10" minGap="1.0" maxSpeed="30.0" laneChangeModel="LC2013" lcStrategic="-1" lcCooperative="-1" lcSpeedGain="0" lcKeepRight="0"/>
    <vType id="Car5" accel="5.0" decel="7.5" emergencyDecel="10" minGap="1.0" maxSpeed="30.0" laneChangeModel="LC2013" lcStrategic="-1" lcCooperative="-1" lcSpeedGain="0" lcKeepRight="0"/>

    <!-- ========================================== -->
    <!-- 3. 車輛實例 (嚴格按時間軸與間隔排序)           -->
    <!--    - 採用 interleaving 技術混合不同車道車輛      -->
    <!--    - 確保同一車道前後車 depart 間距 >= 1.0s    -->
    <!--    - 攻擊者 veh4 位於 veh0 後方 1.0s (約10m)    -->
    <!-- ========================================== -->
    
    <!-- T=0.0s 至 T=0.6s: 佈署所有車道的領頭車 (EVs) -->
    <vehicle id="veh0" type="Car1" depart="0.0" route="r_main" departLane="0" />
    <vehicle id="veh1" type="Car1" depart="0.2" route="r_main" departLane="3" />
    <vehicle id="veh2" type="Car1" depart="0.4" route="r_main" departLane="1" />
    <vehicle id="veh3" type="Car1" depart="0.6" route="r_main" departLane="2" />

    <!-- T=1.0s: 佈署攻擊者於 Lane 0 (緊跟 veh0) -->
    <vehicle id="veh4" type="Car2" depart="1.0" route="r_main" departLane="0" />

    <!-- T=1.2s 至 T=2.0s: 第一波受害車流進入 -->
    <vehicle id="veh5" type="Car3" depart="1.2" route="r_main" departLane="3" />
    <vehicle id="veh6" type="Car4" depart="1.4" route="r_main" departLane="1" />
    <vehicle id="veh7" type="Car5" depart="1.6" route="r_main" departLane="2" />
    <vehicle id="veh8" type="Car3" depart="2.0" route="r_main" departLane="0" />

    <!-- T=2.2s 至 T=3.0s: 第二波受害車流 (強化 Lane 0 & 3 的密度) -->
    <vehicle id="veh9" type="Car4" depart="2.2" route="r_main" departLane="3" />
    <vehicle id="veh10" type="Car5" depart="2.4" route="r_main" departLane="1" />
    <vehicle id="veh11" type="Car3" depart="2.6" route="r_main" departLane="2" />
    <vehicle id="veh12" type="Car4" depart="3.0" route="r_main" departLane="0" />

    <!-- T=3.2s 至 T=4.0s: 第三波受害車流 -->
    <vehicle id="veh13" type="Car5" depart="3.2" route="r_main" departLane="3" />
    <vehicle id="veh14" type="Car3" depart="3.4" route="r_main" departLane="1" />
    <vehicle id="veh15" type="Car4" depart="3.6" route="r_main" departLane="2" />
    <vehicle id="veh16" type="Car5" depart="4.0" route="r_main" departLane="0" />

    <!-- T=4.2s 至 T=5.0s: 第四波受害車流 -->
    <vehicle id="veh17" type="Car3" depart="4.2" route="r_main" departLane="3" />
    <vehicle id="veh18" type="Car4" depart="4.4" route="r_main" departLane="1" />
    <vehicle id="veh19" type="Car5" depart="4.6" route="r_main" departLane="2" />
    <vehicle id="veh20" type="Car3" depart="5.0" route="r_main" departLane="0" />

    <!-- T=5.2s 至 T=6.0s: 高價值區(Lane 0/3)最後增壓 -->
    <vehicle id="veh21" type="Car4" depart="5.2" route="r_main" departLane="3" />
    <vehicle id="veh22" type="Car5" depart="6.0" route="r_main" departLane="0" />

    <!-- T=6.2s 至 T=7.2s: 尾部封堵車流 -->
    <vehicle id="veh23" type="Car3" depart="6.2" route="r_main" departLane="3" />
    <vehicle id="veh24" type="Car4" depart="7.0" route="r_main" departLane="0" />
    <vehicle id="veh25" type="Car5" depart="7.2" route="r_main" departLane="3" />

</routes>